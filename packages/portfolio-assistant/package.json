{
  "name": "portfolio-assistant",
  "version": "0.1.0",
  "description": "Floating portfolio / resume chat widget for Next.js plus an Anthropic-backed Pages API handler factory.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/taylorsegell/career-copilot.git"
  },
  "author": "Taylor Segell",
  "sideEffects": [
    "**/*.css"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./styles.css": "./styles/portfolio-assistant-shell.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "styles"
  ],
  "scripts": {
    "build": "tsup && node scripts/prep-client-directive.mjs",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "clsx": ">=2",
    "lucide-react": ">=0.400",
    "next": ">=15",
    "react": ">=18",
    "react-dom": ">=18",
    "react-markdown": ">=9",
    "remark-gfm": ">=3",
    "tailwind-merge": ">=2"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.19.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "tsup": "^8.5.1",
    "typescript": "~5.9.3"
  }
}
